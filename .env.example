# ====================================================================
# Wellos & Wellos Studio — Environment Variables (v2 / MVP managed-PaaS path)
# ====================================================================
#
# Source of truth: docs/00-V2-per-build-setup.md §4 + §6.6
# (canonical consolidated reference will be docs/09-dev-handoff.md
#  once that doc is exported from the Claude.ai "Rebuild application"
#  project — see docs/MISSING-DOCS.md).
#
# This file is a SCHEMA — values are intentionally empty.
#
# Usage:
#   1. Copy to .env:  cp .env.example .env
#   2. Fill in real values from the team password manager.
#   3. NEVER commit .env (it is gitignored).
#
# When you add a new variable, update this file in the SAME commit,
# plus the password manager, GitHub Actions secrets (if needed at
# build/test time), AND both Railway (backend runtime) and Vercel
# (frontend runtime) for production AND staging environments.
# See docs/00-V2-per-build-setup.md §6.6 — the five-place sync rule.
#
# ====================================================================

# ---------- Database (Supabase Postgres) ----------
# Pooled connection (port 6543) — used at runtime by Railway services.
DATABASE_URL=postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Direct connection (port 5432) — used by `prisma migrate` ONLY.
# Pooler can't run migrations (prepared-statement issue).
DIRECT_URL=postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ---------- Supabase (API + Storage) ----------
SUPABASE_URL=
SUPABASE_ANON_KEY=                                # frontend-safe
SUPABASE_SERVICE_ROLE_KEY=                        # BACKEND ONLY — never ship to client
NEXT_PUBLIC_SUPABASE_URL=                         # frontend mirror
NEXT_PUBLIC_SUPABASE_ANON_KEY=                    # frontend mirror

# ---------- Redis (Upstash) ----------
# BullMQ requires the TCP URL (not the REST URL).
REDIS_URL=rediss://default:<token>@<host>.upstash.io:6379
# REST URL only used if we ever access Redis from a Vercel edge function.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------- Auth (Clerk) ----------
CLERK_SECRET_KEY=                                 # backend
CLERK_PUBLISHABLE_KEY=                            # convenience server reference
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=                # frontend (Next.js)
CLERK_WEBHOOK_SECRET=                             # signing secret for /webhooks/clerk

# ---------- Stripe (platform default + Connect + Terminal) ----------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_CONNECT_CLIENT_ID=                         # for OAuth onboarding of tenants
STRIPE_WEBHOOK_SECRET=                            # per-endpoint, per-env (test vs live)

# ---------- Square (BYO adapter for tenants who already use Square) ----------
SQUARE_APPLICATION_ID=
SQUARE_APPLICATION_SECRET=
SQUARE_OAUTH_REDIRECT_URL=
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_ENVIRONMENT=sandbox                        # 'sandbox' | 'production'

# ---------- Email (Postmark — existing Clarity Labs USA account) ----------
# Per-Server token (NOT the account token). Production server is
# `Wellos - Production`; staging is `Wellos - Sandbox`.
POSTMARK_SERVER_TOKEN=
# We set the Basic Auth user/pass on Postmark webhooks; this is that secret.
POSTMARK_WEBHOOK_SECRET=
# Default From: address for all transactional sends. Sending domain is
# mail.wellos.one (verified DKIM + Return-Path). See memory:
# email_sending_convention for the apex-vs-subdomain decision.
POSTMARK_FROM_EMAIL=noreply@mail.wellos.one
# Postmark Message Streams. `outbound` is the default transactional stream.
# `broadcast` is created upfront so we can switch marketing email onto a
# separate stream later without a migration (per 09-dev-handoff §4.7).
POSTMARK_TRANSACTIONAL_STREAM=outbound
POSTMARK_BROADCAST_STREAM=broadcast

# ---------- SMS (TextLink — 3-SIM paid plan) ----------
TEXTLINK_API_KEY=
TEXTLINK_WEBHOOK_SECRET=
# SIM allocation per docs/textlink-integration-guide.md §3.
# Names below assume Option C (pooled with recipient pinning) — adjust if
# the documented allocation differs.
TEXTLINK_SIM_TRANSACTIONAL=
TEXTLINK_SIM_REMINDERS=
TEXTLINK_SIM_MARKETING=
# Fallback SIM ID when a location has no default_textlink_sim_id configured.
TEXTLINK_DEFAULT_SIM_ID=

# ---------- Observability ----------
SENTRY_DSN_WEB=                                   # Next.js project DSN
SENTRY_DSN_API=                                   # Fastify project DSN
SENTRY_AUTH_TOKEN=                                # CI — for source map upload at deploy
NEXT_PUBLIC_SENTRY_DSN=                           # frontend reference

POSTHOG_KEY=
POSTHOG_HOST=https://us.posthog.com               # or https://eu.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# ---------- Magic-link / token signing ----------
# Used for client-facing magic links (booking confirm/cancel, intake form
# resume, etc.) per Epic 4. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating this invalidates all outstanding magic links.
JWT_SECRET=

# ---------- Feature flags ----------
# MVP: in-DB feature flags via the `feature_flags` table + per-tenant overrides
# in `tenant_feature_flags`. Evaluated at request time, cached in Redis 60s.
# Growth phase: swap to LaunchDarkly / Statsig / Unleash for percentage
# rollouts and experimentation.
FEATURE_FLAGS_PROVIDER=internal                   # 'internal' (MVP) | 'launchdarkly' | 'statsig'

# ---------- App URLs ----------
# Used by the API for building absolute URLs in emails / webhooks.
APP_URL=https://app.<platform-domain>
API_URL=https://api.<platform-domain>
NEXT_PUBLIC_APP_URL=https://app.<platform-domain>
NEXT_PUBLIC_API_URL=https://api.<platform-domain>

# ---------- Phase 2 ONLY (DigitalOcean Droplet migration target) ----------
# Leave unset at MVP. Populated only when the v2 Appendix A migration begins.
# DIGITALOCEAN_ACCESS_TOKEN=
# DO_REGISTRY_NAME=
# S3_ENDPOINT=
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
