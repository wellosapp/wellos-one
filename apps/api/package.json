{
  "name": "@wellos/api",
  "private": true,
  "version": "0.0.0",
  "description": "Wellos API — Fastify backend, deployed to Railway, serves both wellos.one and wellos.studio",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "prisma generate --schema=../../prisma/schema.prisma && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "worker": "node dist/worker.js",
    "dev": "tsx watch --env-file-if-exists=../../.env --env-file-if-exists=.env src/index.ts",
    "worker:dev": "tsx watch --env-file-if-exists=../../.env --env-file-if-exists=.env src/worker.ts",
    "lint": "echo 'lint placeholder — wire ESLint or Biome in a follow-up PR' && exit 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo 'test placeholder — wire Vitest in a follow-up PR' && exit 0",
    "postinstall": "prisma generate --schema=../../prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=../../prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=../../prisma/schema.prisma",
    "db:seed": "prisma db seed --schema=../../prisma/schema.prisma",
    "db:studio": "prisma studio --schema=../../prisma/schema.prisma",
    "bootstrap:admin": "tsx scripts/bootstrap-admin.ts"
  },
  "dependencies": {
    "@wellos/notifications": "workspace:*",
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@clerk/fastify": "^3.1.19",
    "@fastify/cors": "^11.2.0",
    "@prisma/client": "5.22.0",
    "@sentry/node": "8.55.2",
    "@sentry/profiling-node": "8.55.2",
    "bullmq": "^5.34.7",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "fastify": "5.0.0",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.4.2",
    "svix": "^1.92.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "20.16.13",
    "prisma": "5.22.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  },
  "prisma": {
    "schema": "../../prisma/schema.prisma",
    "seed": "tsx ../../prisma/seed.ts"
  }
}
