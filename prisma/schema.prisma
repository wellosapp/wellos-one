// Wellos Prisma schema
//
// MVP: Postgres 16 via Supabase. DATABASE_URL points at the Transaction Pooler
// (port 6543) for runtime; DIRECT_URL points at the Session Pooler (port 5432)
// for `prisma migrate` only — the Transaction Pooler can't run migrations
// because of prepared-statement reuse.
//
// Conventions:
//   - cuid v1 IDs (`@default(cuid())`) for now. Epic 2 spec calls for cuid2;
//     revisit when we upgrade past Prisma 5.x. (Today's blocker: Prisma 6's
//     auto-install-CLI postinstall recurses badly under pnpm 10 workspaces.)
//   - camelCase fields in Prisma, snake_case in Postgres via @map / @@map.
//   - Every tenant-owned table carries `tenant_id` plus a tenant-scoped index.
//   - Soft delete (`deleted_at`) on entities an admin might "delete";
//     join tables, append-only logs, and TTL'd rows hard-delete instead.
//   - Supabase RLS lands in a follow-up PR (placeholder dir at supabase/policies/).
//     The API uses the Supabase service role at runtime, which bypasses RLS;
//     RLS becomes the safety net once any frontend talks to Supabase directly.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Enums ----------

enum ActorType {
  user
  system
  webhook
}

enum ClientIntakeStatus {
  pending
  sent
  completed
  expired
}

// Booking engine state machine (Epic 3). Defer `requested` and `declined`
// until REQUEST_APPROVAL booking policy lands. Allowed transitions live
// in apps/api/src/services/appointmentStateMachine.ts.
enum AppointmentStatus {
  scheduled
  // `requested` — created via public booking when the Service's bookingPolicy
  // is `request_approval`. Occupies the slot for double-book purposes (the
  // EXCLUDE constraint filter is `state NOT IN (cancelled, no_show)`), but
  // staff must approve to move it to `confirmed`. See R2 §11.2.
  requested
  confirmed
  checked_in   @map("checked_in")
  in_progress  @map("in_progress")
  completed
  cancelled
  no_show      @map("no_show")
}

// How a Service may be booked publicly. Drives the public confirm flow:
//   instant          — client confirm creates state=confirmed appointment
//   request_approval — client confirm creates state=requested, awaits staff
//   staff_only       — public booking refused; calendar shows it but contact-to-book
// See R2 §11 (Booking policies) for the spec.
enum BookingPolicy {
  instant
  request_approval @map("request_approval")
  staff_only       @map("staff_only")
}

// ---------- Tier A: Client memory + triage enums (Epic 3) ----------
//
// Per docs/04-booking UI UX Update/wellos-booking-ui-walkthrough-v2-notes-package
// /wellos-booking-ui-walkthrough-v2-notes.md §4.3 + docs/05-booking-enhancements.md
// §§2-4. Decisions Q1-Q11 from session 2026-04-30.

// 12 categories per v2-notes §4.3. `session` and `customer_request` extend the
// master spec's 10-value list to support staff session notes and customer-
// authored pre-visit notes as semantically distinct.
enum ClientNoteCategory {
  general
  preference
  formula
  allergy
  medical
  clinical
  behavioral
  billing
  relationship
  internal
  session
  customer_request
}

enum ClientNotePriority {
  normal
  alert
}

// Author type. The three nullable author FKs on ClientNote disambiguate the
// concrete row; this enum lets us filter/index by type cheaply without a join.
// Invariant (app-layer): exactly one of authorStaffId / authorClientId /
// authorUserId is non-null when authorType in (customer/staff/admin); all
// three are null when authorType = system.
enum ClientNoteAuthorType {
  customer
  staff
  admin
  system
}

// Where the note originated (extend when adding booking surfaces; keep Zod in sync).
enum ClientNoteSourceSurface {
  public_booking
  magic_link_manage
  appointment_detail
  calendar_drawer
  quick_book
  client_profile
  intake_form
  system_transition
}

// Visibility on ClientNote. 5 values per v2-notes §4.3 (extends master spec's
// 3-value model with `customer_submitted` sentinel + `protected_clinical`
// reservation for medspa partition).
enum ClientNoteVisibility {
  location
  provider_only      @map("provider_only")
  admin_only         @map("admin_only")
  customer_submitted @map("customer_submitted")
  protected_clinical @map("protected_clinical")
}

// Visibility on MediaAsset. 3-value enum (Q3 decision); files don't need
// the customer_submitted sentinel because the uploadedByClient boolean
// captures that, and don't need protected_clinical until Phase-2 partition.
// Used to be ClientFileVisibility; renamed during the universal media-asset
// pivot to match the broader MediaAsset table.
enum MediaAssetVisibility {
  location
  provider_only @map("provider_only")
  admin_only    @map("admin_only")
}

// Access class per the R2 spec §2.5. Drives which bucket the object sits in
// and how URLs are generated (CDN-direct vs signed-and-short-lived).
enum MediaAccessClass {
  public_booking    @map("public_booking")
  tenant_staff      @map("tenant_staff")
  client_owned      @map("client_owned")
  protected_medspa  @map("protected_medspa")
  generated
}

// Polymorphic owner of a MediaAsset. Tenant brand, location photos, service
// galleries, staff avatars, client files, appointment uploads, campaign
// QR codes — all in one table with owner_type discriminating.
enum MediaOwnerType {
  tenant
  location
  service
  staff
  client
  appointment
  campaign
}

// Trigger moments at which an alert-priority note must surface.
// Stored as a Postgres enum array on ClientNote.alertTriggers (Q1 decision).
enum ClientNoteAlertTrigger {
  booking
  check_in @map("check_in")
  checkout
}

// Trigger context for an acknowledgment row. Wider than ClientNoteAlertTrigger
// (master spec §5.2.3 adds `manual` for staff acknowledging an alert outside
// the three trigger moments).
enum ClientNoteAckTriggerContext {
  booking
  check_in @map("check_in")
  checkout
  manual
}

// Triage question types per 05-booking-enhancements.md §2.
enum ServiceBookingQuestionType {
  chips_single
  chips_multi
  short_text
  long_text
  slider
  yes_no
  photo_upload
}

enum ServiceContentDeliveryType {
  prep
  aftercare
  reminder_with_content
}

enum ServiceContentDeliveryChannel {
  sms
  email
  both
}

// Waitlist entry state machine (R2 §10).
//   active     — created by a client; no opening matched yet
//   offered    — an opening was found and an offer notification was sent
//                (Epic 8 wires the actual SMS/email; until then the trigger
//                hook only logs "would offer to N").
//   claimed    — client accepted the offer; appointment was created
//   expired    — TTL elapsed without any offer or claim
//   cancelled  — client (or admin) manually cancelled the waitlist signup
enum WaitlistEntryStatus {
  active
  offered
  claimed
  expired
  cancelled
}

// Public catalog / booking UI price presentation (Services & Catalog MVP).
enum ServicePriceDisplayMode {
  fixed
  starting_at @map("starting_at")
  range
  hidden
  consultation
}

// Where the appointment was created from. Surfaces in reporting + abuse
// detection. Tier A column on Appointment (added 2026-04-30).
enum AppointmentSource {
  web
  staff
  widget
  api
  import
  campaign
  walk_in       @map("walk_in")
  quick_book    @map("quick_book")
  calendar_drag @map("calendar_drag")
}

// Staff / calendar block time (calendar-area-features.md §9 — Tier B core).
enum StaffScheduleBlockCategory {
  break
  lunch
  pto
  meeting
  training
  maintenance
  closure
  custom
}

enum ScheduleBlockVisibility {
  internal
  public_busy @map("public_busy")
}

// Epic 5 — first-party intake forms (versioned definitions, submissions).
enum IntakeFormDefinitionStatus {
  draft
  published
  archived
}

enum IntakeFormSubmissionStatus {
  draft
  submitted
}

// Append-only audit row action (expand when amend/redact flows land).
enum IntakeFormSubmissionAuditAction {
  submitted
}

// Staff onboarding forms (W9, license, certifications). Mirrors the IntakeForm
// shape but keyed by staff and not appointment-scoped. Audit includes the full
// lifecycle: created → updated* → submitted, plus voided for future amend flows.
enum StaffOnboardingFormDefinitionStatus {
  draft
  published
  archived
}

enum StaffOnboardingFormSubmissionStatus {
  draft
  submitted
}

enum StaffOnboardingFormSubmissionAuditAction {
  created
  submitted
  updated
  voided
}

// Slot hold lifecycle per R2 §9.4. `active` is reserved until either the
// booking confirms (→ consumed), the TTL elapses (→ expired), or the user
// abandons (→ released). Only `active` rows participate in availability
// conflict checks.
enum SlotHoldStatus {
  active
  consumed
  expired
  released
}

// Tenant-editable file folder taxonomy. Used by ClientFile.folder.
// Per the master spec §5.2.4 default folders. Free string (not enum) on
// the column so tenants can add custom folders, but these are the
// suggested seed values.

// ---------- Tenancy & users ----------

model Tenant {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // ---------- Booking settings (R2 §12.1) — tenant-level defaults ----------
  // Booking policy default lives on Service (already shipped, see BookingPolicy
  // enum + Service.bookingPolicy). These are tenant-wide knobs that resolve
  // down to appointments unless overridden — see bookingSettingsService.
  bookingDepositsEnabled         Boolean @default(false) @map("booking_deposits_enabled")
  bookingDepositAmountCents      Int     @default(5000)  @map("booking_deposit_amount_cents")
  bookingCancellationWindowHours Int     @default(24)    @map("booking_cancellation_window_hours")
  bookingCancellationFeeCents    Int     @default(0)     @map("booking_cancellation_fee_cents")
  bookingNoShowFeeCents          Int     @default(0)     @map("booking_no_show_fee_cents")
  bookingMinNoticeHours          Int     @default(2)     @map("booking_min_notice_hours")
  bookingMaxWindowDays           Int     @default(90)    @map("booking_max_window_days")
  bookingDefaultBufferMinutes    Int     @default(0)     @map("booking_default_buffer_minutes")
  bookingWalkInsAllowed          Boolean @default(true)  @map("booking_walk_ins_allowed")
  bookingTipsEnabled             Boolean @default(true)  @map("booking_tips_enabled")
  /// "email_only" | "email_phone" | "email_name" — validated by Zod at the API edge.
  bookingClientRecognitionMode   String  @default("email_phone")    @map("booking_client_recognition_mode")
  /// Comma-separated role names allowed to override double-book (e.g. "admin,manager").
  bookingOverrideRoles           String  @default("admin,manager")  @map("booking_override_roles")

  /// Tenant-scoped brand color palette. Empty array means "use Wellos defaults".
  /// Phase 1 of the Brand Settings epic — logo + fonts + theme tokens in later
  /// phases. Shape: [{name: string, hex: string}].
  brandColors      Json      @default("[]")             @map("brand_colors")

  /// Tenant logo — uploaded to R2 via the MediaAsset table with
  /// ownerType='tenant'. ON DELETE SET NULL means the tenant loses
  /// its logo display if the asset is deleted (no cascade). Phase 2
  /// of the Brand Settings epic. Phase 3+ adds fonts + theme tokens.
  logoMediaAssetId String?      @map("logo_media_asset_id")
  logoMediaAsset   MediaAsset?  @relation("TenantLogo", fields: [logoMediaAssetId], references: [id], onDelete: SetNull)

  locations                 Location[]
  users                     User[]
  roleAssignments           RoleAssignment[]
  tenantFeatureFlags        TenantFeatureFlag[]
  idempotencyKeys           IdempotencyKey[]
  auditEntries              AuditLog[]
  clients                   Client[]
  staff                     Staff[]
  services                  Service[]
  classes                   Class[]
  classInstances            ClassInstance[]
  recurrenceRules           RecurrenceRule[]
  serviceCategories         ServiceCategory[]
  clientTags                ClientTag[]
  appointments              Appointment[]

  // Tier A
  clientNotes               ClientNote[]
  // Multi-tenant ownership (every MediaAsset has a tenantId).
  mediaAssets               MediaAsset[]              @relation("MediaAssetTenantScope")
  // Tenant as polymorphic owner (brand assets, booking-page hero, policies).
  brandMediaAssets          MediaAsset[]              @relation("MediaAssetTenant")
  tenantMediaRoot           TenantMediaRoot?
  soapNotes                 SoapNote[]
  soapNoteRevisions         SoapNoteRevision[]
  clientNoteAcks            ClientNoteAcknowledgment[]
  serviceBookingQuestions   ServiceBookingQuestion[]
  appointmentBookingAnswers AppointmentBookingAnswer[]
  serviceContentDeliveries  ServiceContentDelivery[]
  staffCalendarFeedTokens   StaffCalendarFeedToken[]
  staffScheduleBlocks       StaffScheduleBlock[]
  intakeFormDefinitions     IntakeFormDefinition[]
  intakeFormSubmissions     IntakeFormSubmission[]
  intakeFormSubmissionAudits IntakeFormSubmissionAudit[]
  staffOnboardingFormDefinitions     StaffOnboardingFormDefinition[]
  staffOnboardingFormSubmissions     StaffOnboardingFormSubmission[]
  staffOnboardingFormSubmissionAudits StaffOnboardingFormSubmissionAudit[]
  slotHolds                 SlotHold[]
  waitlistEntries           WaitlistEntry[]

  // Classes epic Phase 3a — bookings + waitlist back-relations.
  classBookings             ClassBooking[]
  classWaitlistEntries      ClassWaitlistEntry[]

  // Geofence Auto Check-in epic Phase 2 — per-location geofences + audit log.
  locationGeofences         LocationGeofence[]
  classCheckInAttempts      ClassCheckInAttempt[]

  // Geofence Auto Check-in epic PR 8a — magic-link token foundation.
  magicLinkTokens           MagicLinkToken[]

  // Forms System Phase 1 — assignment rules, reminders, per-field file uploads.
  formAssignmentRules       FormAssignmentRule[]
  formReminders             FormReminder[]
  formFileUploads           FormFileUpload[]

  @@index([deletedAt])
  @@map("tenants")
}

model Location {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  name      String
  timezone  String    @default("America/New_York")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  appointments Appointment[]
  mediaAssets  MediaAsset[]  @relation("MediaAssetLocation")
  staffScheduleBlocks StaffScheduleBlock[]
  slotHolds    SlotHold[]
  waitlistEntries WaitlistEntry[]
  classInstances ClassInstance[]
  recurrenceRules RecurrenceRule[]

  // Geofence Auto Check-in epic Phase 2 — at most one geofence per location.
  geofence     LocationGeofence?

  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@map("locations")
}

model User {
  id          String    @id @default(cuid())
  // tenantId nullable: webhook-created users start as orphans (no tenant
  // assigned). Bootstrap admin (sub-step 8) and Epic 2 invite flow assign
  // tenant_id later. Postgres treats NULL as distinct in unique constraints,
  // so multiple orphans can share an email until they're claimed.
  tenantId    String?   @map("tenant_id")
  clerkUserId String?   @unique @map("clerk_user_id")
  email       String
  firstName   String?   @map("first_name")
  lastName    String?   @map("last_name")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant              Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  roleAssignments     RoleAssignment[]
  auditEntries        AuditLog[]       @relation("AuditActor")
  auditSubjectEntries AuditLog[]       @relation("AuditSubject")
  authoredClientNotes ClientNote[]     @relation("ClientNoteAuthorUser")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@map("users")
}

// ---------- RBAC ----------

model Role {
  id          String    @id @default(cuid())
  name        String    @unique // 'super_admin' | 'admin' | 'manager' | 'staff'
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  assignments RoleAssignment[]

  @@map("roles")
}

model RoleAssignment {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([tenantId, userId, roleId])
  @@index([tenantId])
  @@index([userId])
  @@map("role_assignments")
}

// ---------- Feature flags ----------

model FeatureFlag {
  id             String   @id @default(cuid())
  key            String   @unique
  description    String?
  category       String?
  defaultEnabled Boolean  @default(false) @map("default_enabled")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenantOverrides TenantFeatureFlag[]

  @@map("feature_flags")
}

model TenantFeatureFlag {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  featureFlagId String    @map("feature_flag_id")
  enabled       Boolean
  // Plan-limit numbers, e.g. { "maxLocations": 1, "maxStaff": 5 }.
  limits        Json?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  featureFlag FeatureFlag @relation(fields: [featureFlagId], references: [id], onDelete: Restrict)

  @@unique([tenantId, featureFlagId])
  @@index([tenantId])
  @@map("tenant_feature_flags")
}

// ---------- Idempotency ----------

model IdempotencyKey {
  id             String   @id @default(cuid())
  tenantId       String?  @map("tenant_id")
  key            String
  method         String
  path           String
  requestHash    String   @map("request_hash")
  responseStatus Int?     @map("response_status")
  responseBody   Json?    @map("response_body")
  createdAt      DateTime @default(now()) @map("created_at")
  expiresAt      DateTime @map("expires_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@unique([tenantId, key, method, path])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

// ---------- Audit log ----------
// Append-only. No `updatedAt`, no soft-delete; rows are immutable once written.

model AuditLog {
  id            String    @id @default(cuid())
  tenantId      String?   @map("tenant_id")
  actorUserId   String?   @map("actor_user_id")
  actorType     ActorType @map("actor_type")
  // Filled only when the action was performed under super-admin impersonation.
  // `actorUserId` stays the real human (the super-admin); `subjectUserId` is
  // the user whose session was being assumed. Lets the audit trail survive
  // the impersonation flow per docs/SESSION-HANDOFF-2026-05-20.md §6.
  subjectUserId String?   @map("subject_user_id")
  action        String
  entityType    String    @map("entity_type")
  entityId      String    @map("entity_id")
  before        Json?
  after         Json?
  ip            String?
  userAgent     String?   @map("user_agent")
  createdAt     DateTime  @default(now()) @map("created_at")

  tenant  Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actor   User?   @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  subject User?   @relation("AuditSubject", fields: [subjectUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([subjectUserId])
  @@map("audit_log")
}

// ---------- Epic 2: Clients, staff, services ----------
//
// Per docs/09-dev-handoff.md "Epic 2":
//   - Soft delete on Client / Staff / Service / ClientTag (deleted_at).
//   - Email + phone are NOT unique at the DB level (uniqueness is a UI-only
//     duplicate warning — same email can belong to multiple family members,
//     phone numbers change hands).
//   - Tags are a separate table with a M2M join, NOT a JSON array on Client.
//   - Staff working hours stored as a JSON column for MVP; a normalized
//     schedule table is a Phase 2 upgrade.
//   - StaffService is a pure M2M join (no per-staff price/duration overrides
//     yet — add when a real need surfaces).

model Client {
  id                    String             @id @default(cuid())
  tenantId              String             @map("tenant_id")
  firstName             String             @map("first_name")
  lastName              String?            @map("last_name")
  /// How the client prefers to be addressed in booking/CRM (spec: staff-booking-client-crm §3).
  preferredName         String?            @map("preferred_name")
  email                 String?
  phone                 String?
  dateOfBirth           DateTime?          @map("date_of_birth") @db.Date
  addressLine1          String?            @map("address_line1")
  addressLine2          String?            @map("address_line2")
  city                  String?
  state                 String?
  postalCode            String?            @map("postal_code")
  country               String?
  emergencyContactName  String?            @map("emergency_contact_name")
  emergencyContactPhone String?            @map("emergency_contact_phone")
  intakeStatus          ClientIntakeStatus @default(pending) @map("intake_status")
  notes                 String?

  /// Per-tenant sequential client number for support / phone-lookup workflows.
  /// Rendered as "CL-{6-digit zero-padded}" by the admin UI. Computed
  /// application-side via getNextClientNumber (MAX + 1 within the tenant);
  /// the @@unique([tenantId, clientNumber]) constraint catches race-window
  /// collisions so the service layer can retry once.
  clientNumber          Int                @map("client_number")

  // Tier A — Communication preferences (Client CRM #2 from feature matrix).
  // Used by Epic 8 notification dispatch to gate SMS/email sends. Default
  // false so newly-created clients receive both until they opt out.
  smsOptedOut           Boolean            @default(false) @map("sms_opted_out")
  emailOptedOut         Boolean            @default(false) @map("email_opted_out")
  // Optional channel preference. Null = system picks based on booking spec
  // (typically SMS for confirmation, email for receipts). Not stored as an
  // enum yet — values: 'sms' | 'email' | 'both'. Promote to enum when we
  // add the second client-facing notification surface.
  preferredChannel      String?            @map("preferred_channel")

  // Tier A — Banned client flag (Client CRM #9). Booking surfaces (public
  // and staff) check this before allowing creation. `bannedAt` lets us
  // scope reporting; `bannedReason` is internal-only (never shown to
  // banned clients themselves).
  banned                Boolean            @default(false)
  bannedReason          String?            @map("banned_reason")
  bannedAt              DateTime?          @map("banned_at")     @db.Timestamptz(3)

  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")
  deletedAt             DateTime?          @map("deleted_at")

  tenant         Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  tagAssignments ClientTagAssignment[]
  appointments   Appointment[]
  notes_         ClientNote[]          @relation("ClientNoteClient")
  authoredNotes  ClientNote[]          @relation("ClientNoteAuthorClient")
  mediaAssets    MediaAsset[]          @relation("MediaAssetClient")
  soapNotes              SoapNote[]
  intakeFormSubmissions  IntakeFormSubmission[]

  // Classes epic Phase 3a — bookings + waitlist participation back-relations.
  classBookings        ClassBooking[]
  classWaitlistEntries ClassWaitlistEntry[]

  // Geofence Auto Check-in epic Phase 2 — audit log for per-client check-in attempts.
  classCheckInAttempts ClassCheckInAttempt[]

  // Geofence Auto Check-in epic PR 8a — magic-link tokens scoped to this client.
  magicLinkTokens      MagicLinkToken[]

  @@unique([tenantId, clientNumber])
  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, email])
  @@index([tenantId, phone])
  // Banned-flag index for fast booking-time gate.
  @@index([tenantId, banned])
  @@map("clients")
}

model Staff {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  firstName         String    @map("first_name")
  lastName          String?   @map("last_name")
  email             String?
  phone             String?
  // Free-text job title (e.g. "Massage Therapist", "Esthetician"). RBAC roles
  // live separately in RoleAssignment — this is presentation, not authorization.
  jobTitle          String?   @map("job_title")
  // Day-of-week → array of { start, end } shifts. Validated at the API layer
  // via Zod when CRUD lands in E2-S5; stored as JSONB for MVP.
  // Example: { "mon": [{ "start": "09:00", "end": "17:00" }], ... }
  workingHours      Json?     @map("working_hours")
  // Hourly rate stored in cents (integer) to dodge floating-point money math.
  hourlyRateCents   Int?      @map("hourly_rate_cents")
  // Commission as a percentage (0-100). Decimal column for precision.
  commissionRatePct Decimal?  @map("commission_rate_pct") @db.Decimal(5, 2)
  active            Boolean   @default(true)

  // ---------- Per-staff booking override fields (R2 §12) ----------
  // Nullable: null falls through to the tenant-level default at resolution time.
  // See bookingSettingsService.resolveBookingSetting for the two-tier order.
  bookingBufferMinutesOverride  Int?     @map("booking_buffer_minutes_override")
  bookingMinNoticeHoursOverride Int?     @map("booking_min_notice_hours_override")
  /// Spec: tenant enables calendar sync, staff opts in. Non-nullable boolean
  /// because the staff member always has an explicit yes/no — there is no
  /// "fall through to tenant" semantic for this field.
  bookingCalendarSyncOptedIn    Boolean  @default(false) @map("booking_calendar_sync_opted_in")

  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  services     StaffService[]
  appointments Appointment[]
  scheduleBlocks StaffScheduleBlock[]
  waitlistEntries WaitlistEntry[]

  // Tier A inverse relations.
  authoredNotes        ClientNote[]               @relation("ClientNoteAuthorStaff")
  uploadedMediaAssets  MediaAsset[]               @relation("MediaAssetUploadedByStaff")
  ownedMediaAssets     MediaAsset[]               @relation("MediaAssetStaff")
  authoredSoapNotes    SoapNote[]                 @relation("SoapNoteAuthorStaff")
  lockedSoapNotes      SoapNote[]                 @relation("SoapNoteLockedByStaff")
  soapNoteRevisions    SoapNoteRevision[]         @relation("SoapNoteRevisionAuthor")
  noteAcknowledgments  ClientNoteAcknowledgment[] @relation("ClientNoteAckStaff")

  /// Epic 7 — optional hashed ICS subscribe secret (plain token never persisted).
  calendarFeedToken StaffCalendarFeedToken?

  slotHolds SlotHold[]

  /// Staff-side onboarding forms (W9, license, certs). Submissions keyed by staffId.
  onboardingFormSubmissions StaffOnboardingFormSubmission[]

  /// Classes epic Phase 1 — assignments to class templates (M2M via class_instructors).
  classInstructorOf ClassInstructor[]

  /// Classes epic Phase 2a — per-occurrence rows where this staff is instructor.
  classInstancesAsInstructor ClassInstance[]

  /// Classes epic Phase 2b — recurrence rule templates where this staff is instructor.
  recurrenceRulesAsInstructor RecurrenceRule[]

  /// Classes epic Phase 3a — rows where this staff member checked a client in.
  classCheckIns ClassBooking[] @relation("ClassBookingCheckedInBy")

  /// Forms System Phase 1 — submissions this staff member reviewed (provider review flow).
  reviewedIntakeFormSubmissions IntakeFormSubmission[] @relation("IntakeFormSubmissionReviewer")

  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, email])
  @@index([tenantId, active])
  @@map("staff")
}

/// Epic 7 — read-only staff appointment feed (RFC 5545). One active secret per
/// staff row; rotate via regenerate endpoint (invalidates prior URL).
model StaffCalendarFeedToken {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  staffId   String   @unique @map("staff_id")
  tokenHash String   @unique @map("token_hash")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  staff  Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("staff_calendar_feed_tokens")
}

// Tenant-scoped catalog grouping for services (optional FK on Service).
model ServiceCategory {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  name         String
  displayOrder Int       @default(0) @map("display_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  services Service[]
  classes  Class[]   @relation("ServiceCategoryClasses")

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, displayOrder])
  @@map("service_categories")
}

model Service {
  id                 String    @id @default(cuid())
  tenantId           String    @map("tenant_id")
  categoryId         String?   @map("category_id")
  name               String
  description        String?
  // Short blurb for catalog cards / SEO-adjacent surfaces (optional).
  descriptionShort   String?   @map("description_short")
  // Service duration in minutes. The booking engine snaps to this grid.
  durationMinutes    Int       @map("duration_minutes")
  // Base price in cents.
  basePriceCents     Int       @map("base_price_cents")
  // How the public catalog surfaces price (fixed amount vs range vs hidden).
  priceDisplayMode   ServicePriceDisplayMode @default(fixed) @map("price_display_mode")
  // Sort order within category / catalog admin lists.
  displayOrder       Int       @default(0) @map("display_order")
  // When false, hide from public booking catalog (staff calendar may still use).
  publicVisible      Boolean   @default(true) @map("public_visible")
  // Buffer BEFORE this service starts on the same staff member's calendar.
  bufferBeforeMinutes Int      @default(0) @map("buffer_before_minutes")
  // Buffer applied AFTER each appointment of this service for the same staff
  // member, in minutes. Per-staff and per-service-pair buffers are Phase 2.
  bufferAfterMinutes Int       @default(0) @map("buffer_after_minutes")
  // Hex color for calendar rendering (e.g. "#7B9E89"). UI maps to design tokens.
  color              String?
  active             Boolean   @default(true)
  // Public booking policy. Defaults to instant (existing services). See R2 §11.
  bookingPolicy      BookingPolicy @default(instant) @map("booking_policy")

  // Prep / aftercare / what-to-expect content lives in R2 as markdown docs
  // per the R2 UI/UX buildout spec §2.4 + §13.2 (services/{serviceId}/docs/
  // {prep|aftercare|what-to-expect|contraindications}.md). Stored as
  // MediaAsset rows with owner_type='service' + folder='docs'. No DB columns
  // for the content itself.

  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  tenant            Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  category          ServiceCategory?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  staff             StaffService[]
  appointments      Appointment[]
  notes             ClientNote[]
  mediaAssets       MediaAsset[]             @relation("MediaAssetService")
  bookingQuestions  ServiceBookingQuestion[]
  contentDeliveries ServiceContentDelivery[]
  slotHolds         SlotHold[]
  waitlistEntries   WaitlistEntry[]

  /// Forms System Phase 1 — rules mapping this service to a form group.
  formAssignmentRules FormAssignmentRule[]

  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, active])
  @@index([tenantId, categoryId])
  @@index([tenantId, publicVisible])
  @@map("services")
}

// Pure M2M join between Staff and Service. No per-staff overrides yet.
model StaffService {
  staffId   String   @map("staff_id")
  serviceId String   @map("service_id")
  createdAt DateTime @default(now()) @map("created_at")

  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
  @@index([serviceId])
  @@map("staff_services")
}

// ---------- Classes (Phase 1 of the Classes epic) ----------
//
// Class is the TEMPLATE for a group session (yoga, fitness, etc.). Per-occurrence
// scheduling (ClassInstance), bookings, waitlist, and check-in land in Phase 2-4.
// Mirrors Service's CRUD shape with capacity additions (max/min, waitlist).
// ServiceCategory is reused as the catalog grouping.

model Class {
  id                    String         @id @default(cuid())
  tenantId              String         @map("tenant_id")
  name                  String
  shortDescription      String?        @map("short_description")
  longDescription       String?        @map("long_description")
  durationMinutes       Int            @map("duration_minutes")
  basePriceCents        Int            @default(0) @map("base_price_cents")
  maxCapacity           Int            @map("max_capacity")
  minToRun              Int            @default(1) @map("min_to_run")
  allowWaitlist         Boolean        @default(false) @map("allow_waitlist")
  waitlistLimit         Int            @default(0) @map("waitlist_limit")
  color                 String?
  bufferBeforeMinutes   Int            @default(0) @map("buffer_before_minutes")
  bufferAfterMinutes    Int            @default(0) @map("buffer_after_minutes")
  active                Boolean        @default(true)
  categoryId            String?        @map("category_id")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  deletedAt             DateTime?      @map("deleted_at")

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  category        ServiceCategory?  @relation("ServiceCategoryClasses", fields: [categoryId], references: [id], onDelete: SetNull)
  instructors     ClassInstructor[]
  instances       ClassInstance[]
  recurrenceRules RecurrenceRule[]

  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@index([tenantId, active])
  @@index([deletedAt])
  @@map("classes")
}

// ---------- Class instances (Phase 2a of the Classes epic) ----------
//
// Per-occurrence row for a Class template. Phase 2a only ships manual
// creation (admin schedules a one-off workshop/retreat). RecurrenceRule +
// cron-driven generation lands in Phase 2b; ClassBooking / waitlist /
// check-in land in Phase 3-4. `recurrence_rule_id` is nullable here and
// populated by Phase 2b's RecurrenceRule cron when it materialises a
// recurring template's occurrences.
//
// State enum is stored as TEXT — values: 'scheduled' | 'in_progress' |
// 'completed' | 'cancelled'. Zod validates at the API edge (matches the
// Tenant.bookingClientRecognitionMode pattern). Auto-transitions
// scheduled → in_progress → completed are Phase 4 cron work; Phase 2a
// only supports the manual `scheduled → cancelled` move.

model ClassInstance {
  id                  String    @id @default(cuid())
  tenantId            String    @map("tenant_id")
  classId             String    @map("class_id")
  staffId             String    @map("staff_id")
  locationId          String    @map("location_id")
  scheduledStartAt    DateTime  @map("scheduled_start_at")
  scheduledEndAt      DateTime  @map("scheduled_end_at")
  capacityOverride    Int?      @map("capacity_override")
  waitlistOverride    Int?      @map("waitlist_override")
  state               String    @default("scheduled")
  cancelledReason     String?   @map("cancelled_reason")
  cancelledAt         DateTime? @map("cancelled_at")
  recurrenceRuleId    String?   @map("recurrence_rule_id")  // Phase 2b populates
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  class          Class           @relation(fields: [classId], references: [id], onDelete: Restrict)
  staff          Staff           @relation(fields: [staffId], references: [id], onDelete: Restrict)
  location       Location        @relation(fields: [locationId], references: [id], onDelete: Restrict)
  recurrenceRule RecurrenceRule? @relation(fields: [recurrenceRuleId], references: [id], onDelete: SetNull)

  // Classes epic Phase 3a — per-occurrence bookings + waitlist back-relations.
  bookings        ClassBooking[]
  waitlistEntries ClassWaitlistEntry[]

  @@index([tenantId])
  @@index([tenantId, scheduledStartAt])
  @@index([classId])
  @@index([staffId, scheduledStartAt])
  @@index([state])
  @@index([recurrenceRuleId])
  @@map("class_instances")
}

// ---------- Recurrence rules (Phase 2b of the Classes epic) ----------
//
// Templates the admin sets once (e.g. "Vinyasa Flow every Mon/Wed/Fri at 9am
// at Studio A with instructor Alex"). A manual "Generate next 12 weeks"
// endpoint materialises ClassInstance rows from each active rule; that
// endpoint is idempotent so re-runs only insert what's missing. The cron
// that schedules the generator weekly is deferred to Epic 8 (BullMQ).
//
// byday: JSON array of RFC 5545-style day codes — SU, MO, TU, WE, TH, FR, SA.
// startTime: "HH:MM" 24-hour in the rule's timezone.
// timezone: IANA zone (e.g. "America/Chicago") — wall-clock startTime is
//   converted to UTC via date-fns-tz at generation time so DST flips don't
//   shift the class's local hour.
// active=false pauses generation but keeps existing instances. There is no
// hard delete in Phase 2b.
model RecurrenceRule {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  classId         String    @map("class_id")
  staffId         String    @map("staff_id")
  locationId      String    @map("location_id")
  startDate       DateTime  @map("start_date") @db.Date
  endDate         DateTime? @map("end_date") @db.Date
  byday           Json      @default("[]")
  startTime       String    @map("start_time")
  durationMinutes Int       @map("duration_minutes")
  timezone        String
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  class     Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  staff     Staff           @relation(fields: [staffId], references: [id], onDelete: Restrict)
  location  Location        @relation(fields: [locationId], references: [id], onDelete: Restrict)
  instances ClassInstance[]

  @@index([tenantId])
  @@index([classId])
  @@index([tenantId, active])
  @@map("recurrence_rules")
}

// ---------- Class bookings + waitlist (Phase 3a of the Classes epic) ----------
//
// Admin-side rosters. Public /book Classes tab is Phase 3b. Auto-promote on
// cancel is Phase 3c. Payments deferred to Epic 6 — payment_id ships nullable.
//
// Capacity correctness: createBookingOrWaitlist (services/classBookingService)
// runs inside a Serializable transaction with SELECT ... FOR UPDATE on the
// class_instances row, so two simultaneous "book the last seat" calls
// serialize and exactly one wins. The waitlist branch covers the loser when
// the class template's allowWaitlist=true.
//
// Idempotency: every booking carries an idempotency_key (UUID generated by
// the calling UI). The unique index on (tenant_id, idempotency_key) catches
// re-submits — service layer returns the existing row instead of erroring.
//
// State machine (TEXT column, validated at the API edge via Zod — mirrors
// ClassInstance.state). Allowed values:
//   ClassBooking.state         — confirmed | cancelled_by_client |
//                                cancelled_by_studio | no_show | checked_in |
//                                completed
//   ClassWaitlistEntry.state   — waiting | promoted | expired | cancelled
//
// Active-uniqueness (no double-booking, no duplicate waitlist entry) is
// enforced by partial unique indices in the migration SQL — Prisma 5 cannot
// express `@@unique(..., where: ...)` so the constraint lives only in
// migration.sql and the service layer.

model ClassBooking {
  id                       String    @id @default(cuid())
  tenantId                 String    @map("tenant_id")
  classInstanceId          String    @map("class_instance_id")
  clientId                 String    @map("client_id")
  bookedAt                 DateTime  @default(now()) @map("booked_at")
  // Nullable until Epic 6 (Stripe) lands. Phase 3a leaves bookings unpaid.
  paymentId                String?   @map("payment_id")
  state                    String    @default("confirmed")
  checkInMethod            String?   @map("check_in_method")
  checkedInAt              DateTime? @map("checked_in_at")
  checkedInByStaffId       String?   @map("checked_in_by_staff_id")
  // Phase 4 — "late arrival" indicator on a checked-in booking. Visual only;
  // cron-based state transitions defer to Epic 8.
  late                     Boolean   @default(false)
  // Geofence Auto Check-in epic Phase 2 — GPS payload captured when a client
  // self-checks-in via geolocation. All nullable: manual check-ins (the only
  // path pre-Phase 2) leave these unset. `checkInAttempts` counts submissions
  // against the rate limit applied in PR 8.
  checkInLat               Decimal?  @map("check_in_lat") @db.Decimal(11, 8)
  checkInLng               Decimal?  @map("check_in_lng") @db.Decimal(11, 8)
  checkInAccuracyMeters    Int?      @map("check_in_accuracy_meters")
  checkInAttempts          Int       @default(0) @map("check_in_attempts")
  cancellationReason       String?   @map("cancellation_reason")
  cancellationInitiatedBy  String?   @map("cancellation_initiated_by")
  cancelledAt              DateTime? @map("cancelled_at")
  idempotencyKey           String    @map("idempotency_key")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  classInstance     ClassInstance  @relation(fields: [classInstanceId], references: [id], onDelete: Restrict)
  client            Client         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  checkedInByStaff  Staff?         @relation("ClassBookingCheckedInBy", fields: [checkedInByStaffId], references: [id], onDelete: SetNull)

  // Geofence Auto Check-in epic Phase 2 — every check-in attempt against this
  // booking (success or failure) lands here for fraud review.
  attempts          ClassCheckInAttempt[]

  // Geofence Auto Check-in epic PR 8a — magic-link tokens scoped to this booking.
  magicLinkTokens   MagicLinkToken[]

  @@unique([tenantId, idempotencyKey])
  @@index([classInstanceId, state])
  @@index([clientId])
  @@index([state])
  @@map("class_bookings")
}

model ClassWaitlistEntry {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  classInstanceId String    @map("class_instance_id")
  clientId        String    @map("client_id")
  position        Int
  joinedAt        DateTime  @default(now()) @map("joined_at")
  promotedAt      DateTime? @map("promoted_at")
  expiresAt       DateTime? @map("expires_at")
  state           String    @default("waiting")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  classInstance ClassInstance  @relation(fields: [classInstanceId], references: [id], onDelete: Restrict)
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Restrict)

  @@index([classInstanceId, state, position])
  @@index([clientId])
  @@map("class_waitlist_entries")
}

// Pure M2M join between Class and Staff (instructors). First-inserted (or
// explicit) row is marked is_primary=true. Replace-all semantics on update.
model ClassInstructor {
  id        String   @id @default(cuid())
  classId   String   @map("class_id")
  staffId   String   @map("staff_id")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([classId, staffId])
  @@index([staffId])
  @@map("class_instructors")
}

model ClientTag {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  name      String
  // Hex color for tag pill rendering.
  color     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  assignments ClientTagAssignment[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@map("client_tags")
}

// Pure M2M join between Client and ClientTag.
model ClientTagAssignment {
  clientId  String   @map("client_id")
  tagId     String   @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")

  client Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tag    ClientTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([clientId, tagId])
  @@index([tagId])
  @@map("client_tag_assignments")
}

// Staff schedule blocks — breaks, PTO, meetings, closures (calendar-area-features).
// Stored in UTC; UI renders in Location.timezone. Availability + booking creation
// both respect overlaps with these intervals.
model StaffScheduleBlock {
  id           String                     @id @default(cuid())
  tenantId     String                     @map("tenant_id")
  staffId      String                     @map("staff_id")
  /// When set, block applies only when booking at this location; null = all locations for this staff.
  locationId   String?                    @map("location_id")
  title        String
  category     StaffScheduleBlockCategory
  startsAt     DateTime                   @map("starts_at") @db.Timestamptz(3)
  endsAt       DateTime                   @map("ends_at")   @db.Timestamptz(3)
  visibility   ScheduleBlockVisibility    @default(internal)
  createdAt    DateTime                   @default(now()) @map("created_at")
  updatedAt    DateTime                   @updatedAt @map("updated_at")
  deletedAt    DateTime?                  @map("deleted_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  staff    Staff     @relation(fields: [staffId], references: [id], onDelete: Restrict)
  location Location? @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@index([tenantId, staffId, startsAt])
  @@index([staffId, startsAt, endsAt])
  @@index([tenantId, deletedAt])
  @@map("staff_schedule_blocks")
}

// ---------- Epic 3: Booking engine ----------
//
// Per docs/09-dev-handoff.md "Epic 3":
//   - All times in UTC (timestamptz). Local rendering uses Location.timezone.
//   - Availability is COMPUTED, not stored (no materialized slot table).
//   - Postgres EXCLUDE constraint on (staff_id, tstzrange) prevents
//     double-booking at the DB level. Added by hand in the migration.sql
//     because Prisma 5 cannot express EXCLUDE; constraint name is
//     `appointments_no_overlap_per_staff` and lives below.
//   - Default state on admin-created appointments is `confirmed`.
//   - The EXCLUDE filter ignores soft-deleted, cancelled, and no_show rows.
//
// scheduledEndAt is denormalized from `scheduledStartAt + Service.durationMinutes`
// so the EXCLUDE constraint can index it. Service-layer create computes endAt;
// PATCH does not allow editing the time/duration triple (cancel + recreate).

model Appointment {
  id                String            @id @default(cuid())
  tenantId          String            @map("tenant_id")
  locationId        String            @map("location_id")
  clientId          String            @map("client_id")
  staffId           String            @map("staff_id")
  serviceId         String            @map("service_id")

  scheduledStartAt  DateTime          @map("scheduled_start_at") @db.Timestamptz(3)
  scheduledEndAt    DateTime          @map("scheduled_end_at")   @db.Timestamptz(3)

  state             AppointmentStatus @default(confirmed)

  // Tier A — Where the appointment was created from. Reporting + abuse
  // detection. Nullable so existing rows pre-Tier-A migrate cleanly; new
  // rows must always set this from the route layer.
  source            AppointmentSource?

  notes             String?
  createdByUserId   String?           @map("created_by_user_id")
  cancelledAt       DateTime?         @map("cancelled_at")       @db.Timestamptz(3)
  cancelledByUserId String?           @map("cancelled_by_user_id")
  cancelReason      String?           @map("cancel_reason")

  // Price locked at booking time (Services & Catalog spec). Service price edits
  // do not change historical appointments.
  bookedBasePriceCents Int            @map("booked_base_price_cents")

  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt      @map("updated_at")
  deletedAt         DateTime?         @map("deleted_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  location Location @relation(fields: [locationId], references: [id], onDelete: Restrict)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  staff    Staff    @relation(fields: [staffId], references: [id], onDelete: Restrict)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  // Tier A inverse relations.
  notes_              ClientNote[]
  mediaAssets         MediaAsset[]               @relation("MediaAssetAppointment")
  soapNotes           SoapNote[]
  bookingAnswers      AppointmentBookingAnswer[]
  noteAcknowledgments ClientNoteAcknowledgment[]
  intakeFormSubmissions IntakeFormSubmission[]

  // Geofence Auto Check-in epic PR 8a — magic-link tokens scoped to this appointment.
  magicLinkTokens     MagicLinkToken[]

  @@index([tenantId, scheduledStartAt])
  @@index([staffId, scheduledStartAt])
  @@index([clientId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, state, scheduledStartAt])
  // Tier A — source-based reporting (e.g. "appointments via direct campaign link").
  @@index([tenantId, source, scheduledStartAt])
  @@map("appointments")
}

// ---------- Tier A: Client memory + triage tables (Epic 3) ----------
//
// Per docs/04-booking UI UX Update/wellos_booking_coverage_matrix.md.
// Schema decisions Q1-Q11 from session 2026-04-30.

// Client notes — the single most important Tier A table. 12 categories,
// 5-value visibility, 7 source surfaces, alert triggers (Postgres enum
// array per Q1), pinned/archived/expires, author tri-type
// (customer/staff/admin/system) with three nullable FKs (Q5).
model ClientNote {
  id             String                   @id @default(cuid())
  tenantId       String                   @map("tenant_id")
  clientId       String                   @map("client_id")

  category       ClientNoteCategory
  priority       ClientNotePriority       @default(normal)
  title          String?
  body           String

  // Optional links — a note may attach to an appointment, a service, both, or neither.
  appointmentId  String?                  @map("appointment_id")
  serviceId      String?                  @map("service_id")

  authorType     ClientNoteAuthorType     @map("author_type")
  authorStaffId  String?                  @map("author_staff_id")
  authorClientId String?                  @map("author_client_id")
  authorUserId   String?                  @map("author_user_id")

  sourceSurface  ClientNoteSourceSurface  @map("source_surface")
  visibility     ClientNoteVisibility

  // Even a 'location'-visible note is internal-only unless this is true.
  customerVisible Boolean                 @default(false) @map("customer_visible")

  // Postgres enum array (Q1). Empty array means the note does not surface
  // as alert. @default([]) so Prisma always emits the DB DEFAULT and
  // future migrations don't regress to NOT NULL without default.
  alertTriggers  ClientNoteAlertTrigger[] @default([]) @map("alert_triggers")

  pinned         Boolean                  @default(false)
  expiresAt      DateTime?                @map("expires_at")  @db.Timestamptz(3)
  archivedAt     DateTime?                @map("archived_at") @db.Timestamptz(3)

  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt      @map("updated_at")
  deletedAt      DateTime?                @map("deleted_at")

  tenant          Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  client          Client                     @relation("ClientNoteClient", fields: [clientId], references: [id], onDelete: Cascade)
  appointment     Appointment?               @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  service         Service?                   @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  authorStaff     Staff?                     @relation("ClientNoteAuthorStaff", fields: [authorStaffId], references: [id], onDelete: SetNull)
  authorClient    Client?                    @relation("ClientNoteAuthorClient", fields: [authorClientId], references: [id], onDelete: SetNull)
  authorUser      User?                      @relation("ClientNoteAuthorUser", fields: [authorUserId], references: [id], onDelete: SetNull)
  acknowledgments ClientNoteAcknowledgment[]
  attachedAssets  MediaAsset[]               @relation("MediaAssetNote")

  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([clientId, category])
  @@index([appointmentId])
  @@index([serviceId])
  @@index([clientId, priority])
  @@map("client_notes")
}

// Universal polymorphic media asset table per `wellos_calendar_booking_r2_uiux_buildout.md`
// §2.6. Owns ALL R2-backed media — tenant brand assets, location photos,
// service galleries + service docs (prep/aftercare/what-to-expect/contraindications.md),
// staff avatars + intro videos, client reference photos, appointment uploads,
// campaign QR codes, generated thumbnails/optimized variants/exported PDFs.
//
// Polymorphic owner: ownerType discriminates which of the optional FK
// columns is populated. Convention: exactly one of (tenantOwnerId, locationOwnerId,
// serviceOwnerId, staffOwnerId, clientOwnerId, appointmentOwnerId,
// campaignOwnerId) is non-null per row, matching ownerType.
//
// Storage path = R2 object key. Bucket selection follows access_class:
//   public_booking → public bucket (CDN/custom-domain URL)
//   tenant_staff / client_owned / protected_medspa → private/protected
//     bucket (signed URLs, short TTL, RBAC-gated)
//   generated → inherits parent's access class
//
// Soft-delete via deletedAt (auto-filtered by the soft-delete extension).
// archivedAt is a separate "admin archived but not deleted" state — rows
// with archivedAt set still appear in reports but are hidden from active
// surfaces. Both can be set; archived ⊆ active rows in normal queries.
model MediaAsset {
  id              String           @id @default(cuid())
  tenantId        String           @map("tenant_id")

  // Bucket name (e.g. wellos-prod-public-media). Used by signed-URL
  // generation. Resolved from access_class + tenant_media_roots config.
  bucket          String

  // R2 object key. Convention: tenants/{tenantId}/{ownerType}/{ownerId}/{folder}/{id}-{safeFileName}
  // EXIF stripping happens at upload time (backend job).
  objectKey       String           @map("object_key")

  accessClass     MediaAccessClass @map("access_class")

  ownerType       MediaOwnerType   @map("owner_type")
  // Polymorphic owner FKs — exactly one non-null per row matching ownerType.
  // No @relation on ownerType column itself; per-owner FK is below.
  tenantOwnerId      String? @map("tenant_owner_id")
  locationOwnerId    String? @map("location_owner_id")
  serviceOwnerId     String? @map("service_owner_id")
  staffOwnerId       String? @map("staff_owner_id")
  clientOwnerId      String? @map("client_owner_id")
  appointmentOwnerId String? @map("appointment_owner_id")
  campaignOwnerId    String? @map("campaign_owner_id")

  // Optional link to a specific ClientNote — when a note "carries" attached
  // photos. Null when the asset is a free-floating attachment on the
  // appointment / client / service / etc.
  noteId          String?          @map("note_id")

  // Folder taxonomy under the owner (e.g. 'gallery', 'docs', 'before-after',
  // 'avatar', 'intro-video', 'reference-uploads', 'qr', 'thumbnails').
  // Free string so tenants can add custom folders.
  folder          String

  fileName        String           @map("file_name")
  mimeType        String           @map("mime_type")
  sizeBytes       BigInt           @map("size_bytes")
  checksumSha256  String?          @map("checksum_sha256")

  // Image/video metadata.
  width           Int?
  height          Int?
  durationSeconds Int?             @map("duration_seconds")

  altText         String?          @map("alt_text")
  caption         String?

  // Worker-generated variant URLs/keys. Shape: { thumb: { key, width, height }, w600: {...}, w1200: {...}, optimized: {...} }
  variants        Json             @default("{}")

  // Free-form metadata (e.g. EXIF data we kept, source camera model, etc.)
  metadata        Json             @default("{}")

  visibility      MediaAssetVisibility @default(location)

  // Booking spec uses 'protected' boolean independent of access_class for
  // future medspa partition. Set to true for medspa-protected records;
  // worker uses this to migrate to the protected bucket later.
  protected       Boolean          @default(false)

  uploadedByUserId  String?        @map("uploaded_by_user_id")
  uploadedByStaffId String?        @map("uploaded_by_staff_id")
  uploadedByClient  Boolean        @default(false) @map("uploaded_by_client")

  uploadedAt      DateTime         @default(now()) @map("uploaded_at") @db.Timestamptz(3)
  archivedAt      DateTime?        @map("archived_at") @db.Timestamptz(3)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt      @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")

  tenant            Tenant       @relation("MediaAssetTenantScope", fields: [tenantId], references: [id], onDelete: Restrict)
  // Polymorphic owner relations — only the matching one is populated per row.
  tenantOwner       Tenant?      @relation("MediaAssetTenant",      fields: [tenantOwnerId],      references: [id], onDelete: SetNull, map: "media_assets_tenant_owner_fkey")
  locationOwner     Location?    @relation("MediaAssetLocation",    fields: [locationOwnerId],    references: [id], onDelete: SetNull)
  serviceOwner      Service?     @relation("MediaAssetService",     fields: [serviceOwnerId],     references: [id], onDelete: SetNull)
  staffOwner        Staff?       @relation("MediaAssetStaff",       fields: [staffOwnerId],       references: [id], onDelete: SetNull)
  clientOwner       Client?      @relation("MediaAssetClient",      fields: [clientOwnerId],     references: [id], onDelete: SetNull)
  appointmentOwner  Appointment? @relation("MediaAssetAppointment", fields: [appointmentOwnerId], references: [id], onDelete: SetNull)
  // campaignOwner intentionally has no Prisma relation — Campaign table is Tier C.

  note              ClientNote?  @relation("MediaAssetNote",        fields: [noteId], references: [id], onDelete: SetNull)
  uploadedByStaff   Staff?       @relation("MediaAssetUploadedByStaff", fields: [uploadedByStaffId], references: [id], onDelete: SetNull)

  // Back-relation for Tenant.logoMediaAsset.
  tenantLogoBackrefs Tenant[] @relation("TenantLogo")

  /// Forms System Phase 1 — submissions that reference this asset via a per-field upload.
  formFileUploads FormFileUpload[]

  @@unique([bucket, objectKey])
  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, ownerType])
  @@index([tenantOwnerId])
  @@index([locationOwnerId])
  @@index([serviceOwnerId])
  @@index([staffOwnerId])
  @@index([clientOwnerId])
  @@index([appointmentOwnerId])
  @@index([campaignOwnerId])
  @@index([noteId])
  @@index([tenantId, archivedAt])
  @@map("media_assets")
}

// Per-tenant R2 bucket configuration. Provisioned at tenant signup.
// One row per tenant.
model TenantMediaRoot {
  id               String    @id @default(cuid())
  tenantId         String    @unique @map("tenant_id")
  publicBucket     String    @map("public_bucket")
  privateBucket    String    @map("private_bucket")
  // Reserved for medspa-protected partition in a later PR.
  protectedBucket  String?   @map("protected_bucket")
  rootPrefix       String    @map("root_prefix")
  cdnBaseUrl       String?   @map("cdn_base_url")
  createdAt        DateTime  @default(now()) @map("created_at")

  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_media_roots")
}

// Onboarding seed data: which folders to provision per owner type.
// Used by the admin media manager + the tenant signup function.
model MediaFolderTemplate {
  id                  String           @id @default(cuid())
  productScope        String           @map("product_scope") // 'wellos' | 'studio' | 'both'
  ownerType           MediaOwnerType   @map("owner_type")
  folderKey           String           @map("folder_key")
  label               String
  defaultAccessClass  MediaAccessClass @map("default_access_class")
  required            Boolean          @default(false)
  displayOrder        Int              @default(0) @map("display_order")

  @@unique([ownerType, folderKey])
  @@index([ownerType, displayOrder])
  @@map("media_folder_templates")
}

// Clinical SOAP notes. Per Q2 we DROP the 1:1 unique on appointmentId — a
// long appointment may generate multiple SOAP entries (e.g. multi-stage
// medspa procedure).
model SoapNote {
  id              String             @id @default(cuid())
  tenantId        String             @map("tenant_id")
  clientId        String             @map("client_id")
  appointmentId   String             @map("appointment_id")
  authorStaffId   String             @map("author_staff_id")

  subjective      String?
  objective       String?
  assessment      String?
  plan            String?

  additionalNotes String?            @map("additional_notes")
  templateId      String?            @map("template_id")

  icdCodes        String[]           @default([]) @map("icd_codes")
  cptCodes        String[]           @default([]) @map("cpt_codes")

  locked          Boolean            @default(false)
  lockedAt        DateTime?          @map("locked_at")  @db.Timestamptz(3)
  lockedByStaffId String?            @map("locked_by_staff_id")

  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt      @map("updated_at")
  deletedAt       DateTime?          @map("deleted_at")

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  client        Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointment   Appointment        @relation(fields: [appointmentId], references: [id], onDelete: Restrict)
  authorStaff   Staff              @relation("SoapNoteAuthorStaff", fields: [authorStaffId], references: [id], onDelete: Restrict)
  lockedByStaff Staff?             @relation("SoapNoteLockedByStaff", fields: [lockedByStaffId], references: [id], onDelete: SetNull)
  revisions     SoapNoteRevision[]

  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([clientId, createdAt])
  @@index([appointmentId])
  @@map("soap_notes")
}

// Append-only revision history when a locked SoapNote is edited.
model SoapNoteRevision {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  noteId           String   @map("note_id")
  revisionNumber   Int      @map("revision_number")

  subjective       String?
  objective        String?
  assessment       String?
  plan             String?
  additionalNotes  String?  @map("additional_notes")

  revisedByStaffId String   @map("revised_by_staff_id")
  revisionReason   String   @map("revision_reason")
  revisedAt        DateTime @default(now()) @map("revised_at") @db.Timestamptz(3)

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  note           SoapNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  revisedByStaff Staff    @relation("SoapNoteRevisionAuthor", fields: [revisedByStaffId], references: [id], onDelete: Restrict)

  @@unique([noteId, revisionNumber])
  @@index([tenantId])
  @@index([noteId, revisedAt])
  @@map("soap_note_revisions")
}

// Append-only acknowledgment trail for alert-priority notes. Master spec
// §5.2.3: every alert ack is logged with who, when, in what context.
model ClientNoteAcknowledgment {
  id             String                      @id @default(cuid())
  tenantId       String                      @map("tenant_id")
  noteId         String                      @map("note_id")
  staffId        String                      @map("staff_id")
  triggerContext ClientNoteAckTriggerContext @map("trigger_context")
  appointmentId  String?                     @map("appointment_id")
  acknowledgedAt DateTime                    @default(now()) @map("acknowledged_at") @db.Timestamptz(3)

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  note        ClientNote   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  staff       Staff        @relation("ClientNoteAckStaff", fields: [staffId], references: [id], onDelete: Restrict)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([noteId, acknowledgedAt])
  @@index([staffId, acknowledgedAt])
  @@map("client_note_acknowledgments")
}

// Per-service triage question template. Per 05-booking-enhancements.md §2.
// is_gating + gating_rule support medspa contraindication blocking.
model ServiceBookingQuestion {
  id            String                     @id @default(cuid())
  tenantId      String                     @map("tenant_id")
  serviceId     String                     @map("service_id")

  questionKey   String                     @map("question_key")
  questionLabel String                     @map("question_label")
  helperText    String?                    @map("helper_text")

  questionType  ServiceBookingQuestionType @map("question_type")

  // For chips_*: array of { value, label }. For slider: { min, max, step }.
  // For photo_upload: { maxCount }. JSONB.
  options       Json                       @default("[]")

  isRequired    Boolean                    @default(false) @map("is_required")
  isGating      Boolean                    @default(false) @map("is_gating")

  // { if_value, block_with, block_action } JSONB. Null when isGating = false.
  gatingRule    Json?                      @map("gating_rule")

  displayOrder  Int                        @default(0) @map("display_order")

  createdAt     DateTime                   @default(now()) @map("created_at")
  updatedAt     DateTime                   @updatedAt      @map("updated_at")
  deletedAt     DateTime?                  @map("deleted_at")

  tenant  Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  service Service                    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  answers AppointmentBookingAnswer[]

  @@unique([serviceId, questionKey])
  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([serviceId, displayOrder])
  @@map("service_booking_questions")
}

// Per-appointment triage answers with denormalized question snapshot so
// answers survive question edits/deletes.
model AppointmentBookingAnswer {
  id                    String                     @id @default(cuid())
  tenantId              String                     @map("tenant_id")
  appointmentId         String                     @map("appointment_id")
  questionId            String                     @map("question_id")

  questionKeySnapshot   String                     @map("question_key_snapshot")
  questionLabelSnapshot String                     @map("question_label_snapshot")
  questionTypeSnapshot  ServiceBookingQuestionType @map("question_type_snapshot")

  // String, array, number, or { urls } for photo_upload. JSONB.
  answerValue           Json                       @map("answer_value")

  createdAt             DateTime                   @default(now()) @map("created_at")
  updatedAt             DateTime                   @updatedAt      @map("updated_at")

  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  appointment Appointment            @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  question    ServiceBookingQuestion @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@unique([appointmentId, questionId])
  @@index([tenantId])
  @@index([appointmentId])
  @@map("appointment_booking_answers")
}

// Per-service prep / aftercare scheduled delivery rules.
// Per 05-booking-enhancements.md §4. scheduleOffsetMinutes is negative for
// before-appointment, positive for after. Bounds enforced via Zod at the
// API edge (Q7), not at DB level.
model ServiceContentDelivery {
  id                       String                        @id @default(cuid())
  tenantId                 String                        @map("tenant_id")
  serviceId                String                        @map("service_id")

  deliveryType             ServiceContentDeliveryType    @map("delivery_type")
  channel                  ServiceContentDeliveryChannel

  scheduleOffsetMinutes    Int                           @map("schedule_offset_minutes")

  isEnabled                Boolean                       @default(true) @map("is_enabled")

  // Null falls back to the service's R2 markdown docs (services/{id}/docs/
  // prep.md or aftercare.md). Override is a per-delivery template that
  // takes precedence over the default service doc.
  templateOverrideMarkdown String?                       @map("template_override_markdown")

  createdAt                DateTime                      @default(now()) @map("created_at")
  updatedAt                DateTime                      @updatedAt      @map("updated_at")
  deletedAt                DateTime?                     @map("deleted_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, deliveryType, channel])
  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@map("service_content_deliveries")
}

// ---------- Epic 5: Intake form definitions & submissions (MVP slice) ----------
//
// Versioning: rows sharing `groupId` are versions of the same logical form.
// Only one `published` row per group at a time (enforced in the service layer).

model IntakeFormDefinition {
  id        String                     @id @default(cuid())
  tenantId  String                     @map("tenant_id")
  groupId   String                     @map("group_id")
  title     String
  /// Form taxonomy — drives template gallery + admin filters. CHECK constraint
  /// at the DB layer enforces allowed values (forms_system_phase_1_schema).
  formType    String?                  @default("intake") @map("form_type")
  /// Admin-facing helper text shown in the catalog list + form-pick dropdowns.
  description String?
  /// Field templates: array of { key, type, label, ... } — validated at API layer.
  schema    Json
  version   Int
  status    IntakeFormDefinitionStatus @default(draft)
  /// Tenant can hide a form from pickers without deleting history.
  isActive  Boolean                    @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  submissions IntakeFormSubmission[]

  @@unique([tenantId, groupId, version])
  @@index([tenantId])
  @@index([tenantId, groupId])
  @@index([tenantId, status])
  @@map("intake_form_definitions")
}

model IntakeFormSubmission {
  id             String                   @id @default(cuid())
  tenantId       String                   @map("tenant_id")
  definitionId   String                   @map("definition_id")
  /// Nullable for future magic-link flows that start before client linkage.
  clientId       String?                  @map("client_id")
  appointmentId  String?                  @map("appointment_id")
  answers        Json                     @default("{}")
  status         IntakeFormSubmissionStatus @default(draft)

  submittedAt    DateTime?                @map("submitted_at") @db.Timestamptz(3)

  // ---------- Forms System Phase 1 — delivery / signature / review ----------
  // All nullable; existing rows carry no delivery history.
  /// First time the recipient opened the form URL.
  openedAt              DateTime? @map("opened_at")     @db.Timestamptz(3)
  /// First time the recipient typed/clicked into a field (engagement signal).
  startedAt             DateTime? @map("started_at")    @db.Timestamptz(3)
  /// Hard expiry — submission link no longer accepted past this point.
  expiresAt             DateTime? @map("expires_at")    @db.Timestamptz(3)
  /// 'email' | 'sms' | 'both' | 'kiosk' | 'inline_booking' | 'admin_only' (CHECK).
  deliveryChannel       String?   @map("delivery_channel")
  /// { imageBase64?, typedSignature?, signedAt, ip, userAgent, formVersion } — API-layer validated.
  signatureData         Json?     @map("signature_data")
  /// 'unreviewed' | 'reviewed' | 'requires_follow_up' | 'approved' | 'denied' (CHECK).
  reviewStatus          String?   @map("review_status")
  reviewedAt            DateTime? @map("reviewed_at")   @db.Timestamptz(3)
  reviewedByStaffId     String?   @map("reviewed_by_staff_id")
  reviewNotes           String?   @map("review_notes")

  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")

  tenant     Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  definition IntakeFormDefinition       @relation(fields: [definitionId], references: [id], onDelete: Restrict)
  client     Client?                    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  appointment Appointment?              @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  reviewedByStaff Staff?                 @relation("IntakeFormSubmissionReviewer", fields: [reviewedByStaffId], references: [id], onDelete: SetNull)
  audits     IntakeFormSubmissionAudit[]
  reminders  FormReminder[]
  fileUploads FormFileUpload[]

  @@index([tenantId])
  @@index([tenantId, clientId])
  @@index([tenantId, definitionId])
  @@index([appointmentId])
  @@map("intake_form_submissions")
}

// Append-only compliance trail (Epic 5 — IP, UA, version evidence). No updatedAt.
model IntakeFormSubmissionAudit {
  id               String                        @id @default(cuid())
  tenantId         String                        @map("tenant_id")
  submissionId     String                        @map("submission_id")
  action           IntakeFormSubmissionAuditAction
  definitionId     String                        @map("definition_id")
  definitionVersion Int                          @map("definition_version")
  /// Snapshot of the JSON schema the client signed against.
  schemaSnapshot   Json                          @map("schema_snapshot")
  answersSnapshot  Json                          @map("answers_snapshot")

  ip              String?
  userAgent       String?                       @map("user_agent")

  createdAt       DateTime                      @default(now()) @map("created_at") @db.Timestamptz(3)

  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  submission IntakeFormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([submissionId, createdAt])
  @@map("intake_form_submission_audits")
}

// ---------- Forms System Phase 1 — assignment rules / reminders / file uploads ----------
//
// PR 1 of the Forms System rebuild. Schema only — services, routes, UI in
// subsequent PRs.

/// Maps a Service to a form (resolved at runtime to the latest published version
/// of the form's groupId). `formDefinitionGroupId` is intentionally NOT a FK —
/// groupId on IntakeFormDefinition is a version-family identifier, not unique
/// on its own.
model FormAssignmentRule {
  id                            String   @id @default(cuid())
  tenantId                      String   @map("tenant_id")
  serviceId                     String   @map("service_id")
  formDefinitionGroupId         String   @map("form_definition_group_id")
  /// 'optional' | 'soft_required' | 'hard_required' (CHECK).
  requiredLevel                 String   @default("optional") @map("required_level")
  /// 'before_booking' | 'before_appointment' | 'optional' (CHECK).
  timing                        String   @default("before_appointment")
  sendAutomaticallyAfterBooking Boolean  @default(true) @map("send_automatically_after_booking")
  requireProviderReview         Boolean  @default(false) @map("require_provider_review")
  /// Submission expires N days after send. NULL = never expires. Capped 1..365.
  expiresAfterDays              Int?     @map("expires_after_days")
  active                        Boolean  @default(true)
  createdAt                     DateTime @default(now()) @map("created_at")
  updatedAt                     DateTime @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, formDefinitionGroupId])
  @@index([tenantId])
  @@index([serviceId])
  @@map("form_assignment_rule")
}

/// Scheduled reminders for unsubmitted assignments. PR 11 wires the cron that
/// processes these. Lifecycle: sent_at fills when the cron sends; cancelled_at
/// fills when the submission completes before the reminder fires.
model FormReminder {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  submissionId  String    @map("submission_id")
  scheduledFor  DateTime  @map("scheduled_for")
  /// 'email' | 'sms' | 'both' (CHECK).
  channel       String    @default("email")
  sentAt        DateTime? @map("sent_at")
  cancelledAt   DateTime? @map("cancelled_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  submission IntakeFormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  // Migration also creates a PARTIAL index on scheduled_for
  // WHERE sent_at IS NULL AND cancelled_at IS NULL (cron lookup hot path).
  // Prisma's @@index can't carry a WHERE clause, so we declare it in raw SQL.
  @@index([submissionId])
  @@index([tenantId])
  @@map("form_reminder")
}

/// Per-field file attachments to a submission. References an existing MediaAsset
/// (R2-backed). RESTRICT on media_asset_id prevents orphaning a submission's
/// audit history — the app layer should soft-delete files instead.
model FormFileUpload {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  submissionId String   @map("submission_id")
  /// Which field in the form schema this file belongs to.
  fieldKey     String   @map("field_key")
  mediaAssetId String   @map("media_asset_id")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  submission IntakeFormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  mediaAsset MediaAsset           @relation(fields: [mediaAssetId], references: [id], onDelete: Restrict)

  @@index([submissionId])
  @@index([tenantId])
  @@map("form_file_upload")
}

// ---------- Staff onboarding forms (W9, license, certs) ----------
//
// Mirrors the IntakeForm trio (definition / submission / audit) but keyed by
// staffId and not appointment-scoped. Submissions persist as drafts until the
// staff member (or admin on their behalf) submits — submitting locks the row
// and writes an audit row with the schema + answers snapshot.

model StaffOnboardingFormDefinition {
  id        String                                  @id @default(cuid())
  tenantId  String                                  @map("tenant_id")
  groupId   String                                  @map("group_id")
  title     String
  /// Field templates: array of { key, type, label, ... } — validated at API layer.
  schema    Json
  version   Int
  status    StaffOnboardingFormDefinitionStatus     @default(draft)
  isActive  Boolean                                 @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant                          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  submissions StaffOnboardingFormSubmission[]

  @@unique([tenantId, groupId, version])
  @@index([tenantId])
  @@index([tenantId, groupId])
  @@index([tenantId, status])
  @@map("staff_onboarding_form_definitions")
}

model StaffOnboardingFormSubmission {
  id             String                                  @id @default(cuid())
  tenantId       String                                  @map("tenant_id")
  definitionId   String                                  @map("definition_id")
  staffId        String                                  @map("staff_id")
  answers        Json                                    @default("{}")
  status         StaffOnboardingFormSubmissionStatus     @default(draft)

  submittedAt    DateTime?                               @map("submitted_at") @db.Timestamptz(3)

  createdAt      DateTime                                @default(now()) @map("created_at")
  updatedAt      DateTime                                @updatedAt @map("updated_at")

  tenant     Tenant                              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  definition StaffOnboardingFormDefinition       @relation(fields: [definitionId], references: [id], onDelete: Restrict)
  staff      Staff                               @relation(fields: [staffId], references: [id], onDelete: Restrict)
  audits     StaffOnboardingFormSubmissionAudit[]

  @@index([tenantId])
  @@index([tenantId, staffId])
  @@index([tenantId, definitionId])
  @@map("staff_onboarding_form_submissions")
}

// Append-only compliance trail. No updatedAt.
model StaffOnboardingFormSubmissionAudit {
  id                String                                          @id @default(cuid())
  tenantId          String                                          @map("tenant_id")
  submissionId      String                                          @map("submission_id")
  action            StaffOnboardingFormSubmissionAuditAction
  definitionId      String                                          @map("definition_id")
  definitionVersion Int                                             @map("definition_version")
  schemaSnapshot    Json                                            @map("schema_snapshot")
  answersSnapshot   Json                                            @map("answers_snapshot")

  ip                String?
  userAgent         String?                                         @map("user_agent")

  createdAt         DateTime                                        @default(now()) @map("created_at") @db.Timestamptz(3)

  tenant     Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  submission StaffOnboardingFormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([submissionId, createdAt])
  @@map("staff_onboarding_form_submission_audits")
}

// ---------- Slot holds (R2 §9) ----------
//
// Short-lived reservations that block a (staff, time) tuple while a client
// works through the booking flow. Default TTL is 7 minutes (see services/
// slotHoldService.ts). Lifecycle: active → consumed | expired | released.
//
// Conflict semantics mirror Appointment overlap (half-open ranges) but live
// in a separate table so an expired/released hold can be ignored cheaply and
// so we never have to GC them from the appointments table. The availability
// engine subtracts active hold ranges from candidate slots (minus holds
// owned by the requesting client, identified by `created_by_fingerprint`).
model SlotHold {
  id                   String         @id @default(cuid())
  tenantId             String         @map("tenant_id")
  locationId           String         @map("location_id")
  serviceId            String         @map("service_id")
  staffId              String         @map("staff_id")
  resourceId           String?        @map("resource_id")
  startsAt             DateTime       @map("starts_at")    @db.Timestamptz(3)
  endsAt               DateTime       @map("ends_at")      @db.Timestamptz(3)
  expiresAt            DateTime       @map("expires_at")   @db.Timestamptz(3)
  status               SlotHoldStatus @default(active)
  idempotencyKey       String?        @map("idempotency_key")
  createdByFingerprint String?        @map("created_by_fingerprint")
  createdAt            DateTime       @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  location Location @relation(fields: [locationId], references: [id], onDelete: Restrict)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  staff    Staff    @relation(fields: [staffId], references: [id], onDelete: Restrict)

  @@index([tenantId, status, expiresAt])
  @@index([staffId, startsAt, endsAt, status])
  @@map("slot_holds")
}

// ---------- R2 §10: Waitlist ----------
//
// Clients join the waitlist when no slot fits. When an opening appears
// (appointment cancellation, schedule change, manual staff trigger), a
// worker (Epic 8) finds eligible entries and offers the slot via SMS/email.
// This phase ships the schema, CRUD, and matching engine. The
// transitionAppointmentState → cancelled hook calls
// findEligibleEntriesForOpening and only logs "would offer to N" — the
// actual notification dispatch lands with the BullMQ worker in Epic 8.
//
// Tenant scoping: every query passes tenantId. Soft-delete is intentionally
// omitted (status=cancelled / expired serves the same role and surfaces in
// reporting). The unique active-entry-per-(client,service) invariant is
// enforced in the service layer (createWaitlistEntry upserts on conflict).
model WaitlistEntry {
  id                   String              @id @default(cuid())
  tenantId             String              @map("tenant_id")
  locationId           String              @map("location_id")
  serviceId            String              @map("service_id")
  /// Optional preferred staff; null means any eligible staff for the service.
  staffId              String?             @map("staff_id")

  contactName          String              @map("contact_name")
  contactEmail         String?             @map("contact_email")
  contactPhone         String?             @map("contact_phone")

  /// Earliest moment the client would accept (inclusive). Null = any time.
  preferredStart       DateTime?           @map("preferred_start")       @db.Timestamptz(3)
  /// Latest moment the client would accept (exclusive). Null = any time.
  preferredEnd         DateTime?           @map("preferred_end")         @db.Timestamptz(3)
  /// 'morning' | 'afternoon' | 'evening' | 'any'. Free string to keep
  /// migrations cheap; Zod constrains values at the API edge.
  preferredTimeOfDay   String?             @map("preferred_time_of_day")

  smsOptIn             Boolean             @default(false) @map("sms_opt_in")
  notes                String?

  status               WaitlistEntryStatus @default(active)
  /// Default created_at + 14d (R2 §10.1). Service layer computes on create.
  ttlExpiresAt         DateTime            @map("ttl_expires_at")        @db.Timestamptz(3)
  offeredAt            DateTime?           @map("offered_at")            @db.Timestamptz(3)
  /// When a manual or worker-driven offer references a concrete appointment.
  /// No FK — the appointment may not exist yet (worker creates it after claim).
  offeredAppointmentId String?             @map("offered_appointment_id")
  claimedAt            DateTime?           @map("claimed_at")            @db.Timestamptz(3)

  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  location Location @relation(fields: [locationId], references: [id], onDelete: Restrict)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  staff    Staff?   @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, ttlExpiresAt])
  @@index([serviceId, status])
  @@index([staffId, status])
  @@map("waitlist_entries")
}

// ---------- Geofence Auto Check-in (Phase 2 of the Geofence epic) ----------
//
// See docs/specs/geofence-check-in-epic.md § Phase 2.
//
// Tables in this section:
//   - LocationGeofence: per-location geofence configuration (center, radius,
//     check-in windows, enabled toggle). Unique on locationId — one geofence
//     per location.
//   - ClassCheckInAttempt: append-only audit log for fraud review and
//     debugging. Every check-in attempt (manual or geofence, success or
//     failure) writes a row. NOT soft-deletable — immutable history.
//
// Routes, services, and UI all defer to PRs 6-10 of this epic. This is a
// schema-only landing so subsequent slices can be built against a stable DB.

model LocationGeofence {
  id                          String   @id @default(cuid())
  tenantId                    String   @map("tenant_id")
  locationId                  String   @unique @map("location_id")
  centerLat                   Decimal  @map("center_lat") @db.Decimal(11, 8)
  centerLng                   Decimal  @map("center_lng") @db.Decimal(11, 8)
  radiusMeters                Int      @default(50)  @map("radius_meters")
  checkInWindowBeforeMinutes  Int      @default(15)  @map("check_in_window_before_minutes")
  checkInWindowAfterMinutes   Int      @default(5)   @map("check_in_window_after_minutes")
  enabled                     Boolean  @default(true)
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt      @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("location_geofence")
}

model ClassCheckInAttempt {
  id                          String   @id @default(cuid())
  tenantId                    String   @map("tenant_id")
  classBookingId              String   @map("class_booking_id")
  clientId                    String   @map("client_id")
  attemptedAt                 DateTime @default(now()) @map("attempted_at")
  /// 'geofence' | 'manual' — enforced by check constraint in migration SQL.
  method                      String
  /// 'success' | 'out_of_range' | 'out_of_window' | 'low_accuracy' |
  /// 'suspicious_pattern' | 'rate_limited' | 'error' — enforced by check
  /// constraint in migration SQL.
  result                      String
  submittedLat                Decimal? @map("submitted_lat") @db.Decimal(11, 8)
  submittedLng                Decimal? @map("submitted_lng") @db.Decimal(11, 8)
  submittedAccuracyMeters     Int?     @map("submitted_accuracy_meters")
  distanceFromGeofenceMeters  Decimal? @map("distance_from_geofence_meters") @db.Decimal(10, 2)
  userAgent                   String?  @map("user_agent")
  ipAddress                   String?  @map("ip_address")
  createdAt                   DateTime @default(now()) @map("created_at")

  tenant       Tenant       @relation(fields: [tenantId],       references: [id], onDelete: Restrict)
  classBooking ClassBooking @relation(fields: [classBookingId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId],       references: [id], onDelete: Cascade)

  @@index([tenantId, attemptedAt])
  @@index([classBookingId, attemptedAt])
  @@index([clientId, attemptedAt])
  @@map("class_check_in_attempt")
}

// ---------- Magic Link Token (PR 8a of the Geofence Auto Check-in epic) ----------
//
// Bearer-token foundation for unauthenticated client surfaces. PR 8b uses it
// for the geofence check-in flow (purpose='geofence_check_in'). The
// 'manage_booking' purpose is reserved for a future manage-flow revival.
//
// Conventions:
//   - Raw token is NEVER persisted. We store a SHA-256 hex digest in
//     `tokenHash`; verifyToken recomputes the hash from the inbound bearer
//     header and looks it up by unique index.
//   - At least one of (clientId, classBookingId, appointmentId) is NOT NULL.
//     Enforced by `magic_link_token_scope_check` in migration SQL.
//   - Purpose is constrained to the listed values by check constraint;
//     extend the constraint when adding a new purpose.
//   - Lifecycle is `revokedAt` + `expiresAt`. NOT in SOFT_DELETE_MODELS — the
//     cron purges rows that have been expired >30 days; revoked rows stay
//     until they expire so verifyToken can return TOKEN_REVOKED instead of
//     INVALID_TOKEN (helps diagnose "I rotated my link" support tickets).

model MagicLinkToken {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  clientId        String?   @map("client_id")
  classBookingId  String?   @map("class_booking_id")
  appointmentId   String?   @map("appointment_id")
  tokenHash       String    @unique @map("token_hash")
  /// 'geofence_check_in' | 'manage_booking' — enforced by check constraint in migration SQL.
  purpose         String
  expiresAt       DateTime  @map("expires_at")
  lastUsedAt      DateTime? @map("last_used_at")
  revokedAt       DateTime? @map("revoked_at")
  useCount        Int       @default(0) @map("use_count")
  createdAt       DateTime  @default(now()) @map("created_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client       Client?       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  classBooking ClassBooking? @relation(fields: [classBookingId], references: [id], onDelete: Cascade)
  appointment  Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([tenantId])
  @@map("magic_link_token")
}
