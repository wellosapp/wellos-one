# Next.js + Sentry webpack resolves @sentry/nextjs from several contexts; hoisting
# @sentry/* avoids intermittent "Can't resolve '@sentry/nextjs'" under pnpm strict layout.
public-hoist-pattern[]=@sentry/*
# Sentry's webpack loaders and Next resolve these via paths that break under strict isolation.
public-hoist-pattern[]=@swc/helpers
public-hoist-pattern[]=rollup

# Allow pnpm to relayout node_modules when hoist patterns change (non-interactive / CI).
confirm-modules-purge=false

# Windows: default hardlink/import can hit ERR_PNPM_ENOTEMPTY (AV/indexers locking files).
# Copy is slower but avoids half-written node_modules when rmdir fails mid-import.
package-import-method=copy

# Fewer parallel imports can reduce EPERM when Defender/indexers lock native .node binaries.
child-concurrency=1
